# Copy to .env before `docker compose up` if you want to override defaults.

# Password for the bundled Postgres (never exposed beyond the compose network
# except on localhost:55432 for development).
POSTGRES_PASSWORD=bookking

# Exchange-rate source (ECB-backed, no API key required).
FX_API_URL=https://api.frankfurter.app

# Currency everything is converted to for display. Change later in Settings.
DEFAULT_DISPLAY_CURRENCY=USD

# Optional HTTP Basic auth (comma-separated user:pass pairs). Required before
# opening BookKing to your LAN — see README. Example:
# BOOKKING_AUTH_USERS=admin:secret,phone:other-secret

# TLS is auto-generated on first start (stored in the caddy-data Docker volume).
# Optional: browser-trusted local certs via mkcert (overrides auto-generated when
# cert.pem and key.pem exist in certs/):
#   scripts/setup-certs.sh   # Windows: .\scripts\setup-certs.ps1
# Optional: include your LAN IP in the auto-generated cert (comma-separated):
# BOOKKING_TLS_SANS=192.168.1.42
# Or use Let's Encrypt instead (public domain required; auto-renewal):
# BOOKKING_DOMAIN=bookking.example.com
# ACME_EMAIL=you@example.com

# Used when running the app outside Docker (npm run dev in app/):
# DATABASE_URL=postgres://supabase_admin:bookking@localhost:55432/postgres
# BOOKKING_AUTH_USERS=dev:local-only
